---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div
  class={`pointer-events-none absolute inset-0 overflow-hidden ${className}`}
>
  <div
    class="absolute left-[8%] top-[12%] h-56 w-56 rounded-full bg-cyan-400/20 blur-[120px] animate-pulse"
  >
  </div>
  <div
    class="absolute right-[10%] top-[18%] h-72 w-72 rounded-full bg-fuchsia-500/20 blur-[140px] animate-pulse"
  >
  </div>
  <div
    class="absolute bottom-[10%] left-[20%] h-64 w-64 rounded-full bg-indigo-500/20 blur-[140px] animate-pulse"
  >
  </div>
  <div
    class="absolute bottom-[18%] right-[18%] h-40 w-40 rounded-full bg-amber-300/10 blur-[100px] animate-pulse"
  >
  </div>
</div>

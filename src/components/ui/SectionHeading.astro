---
interface Props {
  kicker?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  maxWidth?: string;
  className?: string;
}

const {
  kicker,
  title,
  description,
  align = "left",
  maxWidth = "max-w-3xl",
  className = "",
} = Astro.props;

const alignment =
  align === "center"
    ? "mx-auto text-center items-center"
    : "text-left items-start";
---

<div class={`flex flex-col ${alignment} ${maxWidth} ${className}`}>
  {kicker && <p class="section-kicker">{kicker}</p>}

  <h2 class="mt-4 text-5xl text-white md:text-6xl">
    {title}
  </h2>

  {
    description && (
      <p class="mt-5 text-lg leading-8 text-[rgb(var(--color-text-secondary))]">
        {description}
      </p>
    )
  }
</div>

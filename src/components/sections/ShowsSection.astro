---
import SectionHeading from "../ui/SectionHeading.astro";
import Reveal from "../ui/Reveal.astro";

const shows = [
  {
    city: "Miami, FL",
    date: "25 Abril",
    venue: "Venue placeholder",
    status: "Entradas disponibles",
  },
  {
    city: "Orlando, FL",
    date: "11 Mayo",
    venue: "Venue placeholder",
    status: "Últimos tickets",
  },
  {
    city: "Tampa, FL",
    date: "24 Mayo",
    venue: "Venue placeholder",
    status: "Nueva fecha",
  },
];
---

<section id="shows" class="section-shell relative overflow-hidden">
  <div class="container-shell">
    <Reveal>
      <SectionHeading
        kicker="Shows y gira"
        title="Próximas fechas. Próxima locura."
        description="Aquí luego podrás hablar de gira, ciudades, energía en vivo y venta de tickets."
      />
    </Reveal>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {shows.map((show, index) => (
        <Reveal delay={`${index * 120}ms`}>
          <article class="glow-panel group relative overflow-hidden p-6 transition duration-300 hover:-translate-y-2">
            <div class="absolute inset-x-0 top-0 h-1 bg-[linear-gradient(90deg,rgb(var(--color-electric-blue)),rgb(var(--color-vivid-magenta)),rgb(var(--color-warm-spark)))]"></div>

            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[rgb(var(--color-neon-cyan))]">
              {show.date}
            </p>

            <h3 class="mt-5 text-3xl text-white">{show.city}</h3>
            <p class="mt-3 text-base text-[rgb(var(--color-text-secondary))]">{show.venue}</p>

            <div class="mt-8 flex items-center justify-between gap-4">
              <span class="rounded-full border border-white/10 bg-white/5 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-[rgb(var(--color-warm-spark))]">
                {show.status}
              </span>

              <a href="#" class="text-sm font-semibold text-white transition group-hover:text-[rgb(var(--color-neon-cyan))]">
                Comprar ticket →
              </a>
            </div>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
---
const episodes = [1, 2, 3];
---

<section id="episodios" class="section-shell">
  <div class="container-shell">
    <div class="mb-10 max-w-2xl">
      <p class="section-kicker">Episodios y clips</p>
      <h2 class="mt-4 text-5xl text-white md:text-6xl">Momentos que no se quedan en el estudio.</h2>
      <p class="mt-5 text-lg leading-8 text-[rgb(var(--color-text-secondary))]">
        Aquí irán los episodios o clips destacados. Podemos conectar luego con YouTube, Spotify, cards estáticas o embeds selectivos.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {episodes.map((item) => (
        <article class="glow-panel overflow-hidden p-3">
          <!-- PLACEHOLDER DE THUMBNAIL:
               Reemplaza con thumbnails reales de episodios o clips.
               Ruta sugerida: /images/episodes/episode-01.webp -->
          <div class="aspect-video rounded-[1.25rem] bg-[linear-gradient(135deg,rgba(37,199,255,0.18),rgba(255,47,179,0.14),rgba(255,211,107,0.12))]"></div>
          <div class="p-4">
            <p class="text-sm uppercase tracking-[0.18em] text-[rgb(var(--color-neon-cyan))]">Clip destacado</p>
            <h3 class="mt-3 text-2xl text-white">Título placeholder del episodio o clip</h3>
            <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
              Espacio para resumen corto del contenido o momento viral.
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
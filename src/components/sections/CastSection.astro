---
import CharacterSelect from "../islands/CharacterSelect";
---

<section id="cast" class="section-shell relative overflow-hidden">
  <div class="container-shell">
    <div class="mb-10 max-w-3xl">
      <p class="section-kicker">El crew</p>
      <h2 class="mt-4 text-5xl text-white md:text-6xl">
        Selecciona un personaje.
      </h2>
      <p class="mt-5 text-lg leading-8 text-[rgb(var(--color-text-secondary))]">
        Explora quién es quién dentro del universo del show, conoce su energía,
        su rol y algunos de sus mejores momentos.
      </p>
    </div>

    <CharacterSelect client:load />
  </div>
</section>

<section id="top" class="relative isolate min-h-screen overflow-hidden pt-32">
  <!-- PLACEHOLDER DE BACKGROUND:
       Usa aquí la imagen energética aprobada como base del hero.
       Ruta sugerida: /images/hero/hero-bg-energy.webp
       Idealmente exportada optimizada en webp/avif.
       Esta imagen NO debe llevar texto incrustado. -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/hero-bg-energy.webp"
      alt=""
      class="h-full w-full scale-110 object-cover opacity-70"
    />
    <div class="hero-energy-mask absolute inset-0"></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(7,10,30,0.28)_45%,rgba(4,6,18,0.88)_100%)]"
    >
    </div>
  </div>

  <div class="grid-noise absolute inset-0"></div>

  <div
    class="container-shell relative z-10 flex min-h-[calc(100vh-6rem)] items-center py-14"
  >
    <div class="grid w-full items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="max-w-3xl">
        <span class="eyebrow">Podcast · Shows · Miami · Comunidad</span>

        <h1
          class="mt-6 text-6xl leading-[0.92] text-white sm:text-7xl lg:text-[7rem]"
        >
          EL SHOW<br />
          <span class="text-gradient-electric">NO SE APAGA</span>
        </h1>

        <p
          class="mt-6 max-w-2xl text-lg leading-8 text-[rgb(var(--color-text-secondary))] md:text-xl"
        >
          Comedia, actualidad, energía escénica y un universo digital que se
          siente vivo de principio a fin.
        </p>

        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <a
            href="#shows"
            class="button-primary inline-flex items-center justify-center rounded-full px-7 py-4 text-base font-semibold transition hover:-translate-y-1"
          >
            Explorar shows
          </a>
          <a
            href="#episodios"
            class="button-secondary inline-flex items-center justify-center rounded-full px-7 py-4 text-base font-semibold transition hover:-translate-y-1"
          >
            Ver episodios
          </a>
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          <span
            class="rounded-full border border-cyan-300/20 bg-white/5 px-4 py-2 text-sm text-[rgb(var(--color-text-secondary))]"
            >Actualidad</span
          >
          <span
            class="rounded-full border border-fuchsia-300/20 bg-white/5 px-4 py-2 text-sm text-[rgb(var(--color-text-secondary))]"
            >Humor</span
          >
          <span
            class="rounded-full border border-cyan-300/20 bg-white/5 px-4 py-2 text-sm text-[rgb(var(--color-text-secondary))]"
            >Live Shows</span
          >
          <span
            class="rounded-full border border-amber-300/20 bg-white/5 px-4 py-2 text-sm text-[rgb(var(--color-text-secondary))]"
            >Podcast</span
          >
        </div>
      </div>

      <div
        class="relative flex min-h-[560px] items-end justify-center lg:min-h-[680px]"
      >
        <div
          class="absolute bottom-12 h-72 w-72 rounded-full bg-cyan-400/30 blur-[130px]"
        >
        </div>
        <div
          class="absolute right-10 top-10 h-56 w-56 rounded-full bg-fuchsia-500/30 blur-[130px]"
        >
        </div>

        <!-- PLACEHOLDER PRINCIPAL DE FOTO HERO:
             Aquí va la imagen recortada o compuesta de Los Pichy Boys.
             Recomendación: PNG/WebP con fondo limpio o ya recortado.
             Ruta sugerida: /images/hero/hero-main.webp
             Ideal: pose con energía, iluminación dramática, tamaño vertical grande. -->
        <img
          src="/images/hero/hero-main.webp"
          alt="Los Pichy Boys"
          class="relative z-10 max-h-[760px] w-auto object-contain drop-shadow-[0_24px_80px_rgba(0,0,0,0.55)]"
        />
      </div>
    </div>
  </div>
</section>

<section id="top" class="relative isolate min-h-screen overflow-hidden pt-24 lg:pt-32">
  <!-- Background principal -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/hero-bg-energy.webp"
      alt=""
      class="h-full w-full scale-110 object-cover opacity-75"
    />

    <div class="hero-energy-mask absolute inset-0"></div>

    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(7,10,30,0.16)_34%,rgba(4,6,18,0.94)_100%)]"
    ></div>

    <!-- Glow central para hacer el hero más dramático -->
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_50%_42%,rgba(60,180,255,0.18)_0%,rgba(237,58,180,0.12)_18%,transparent_48%)]"
    ></div>

    <!-- Oscurecimiento inferior -->
    <div
      class="absolute inset-x-0 bottom-0 h-[42%] bg-[linear-gradient(to_top,rgba(4,6,18,0.98)_0%,rgba(4,6,18,0.72)_46%,transparent_100%)]"
    ></div>
  </div>

  <div class="grid-noise absolute inset-0"></div>

  <!-- Crew grande, flotante y más protagonista -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 z-[1] flex justify-center"
  >
    <img
      src="/images/hero/hero-main.webp"
      alt="Los Pichy Boys"
      class="animate-float-slow
      w-[150vw] max-w-none
      translate-y-[2%]
      sm:w-[322vw] sm:translate-y-0
      lg:w-[min(112vw,1650px)] lg:justify-end lg:translate-x-[12%]
      xl:translate-x-[16%]
      h-auto object-contain opacity-95
      drop-shadow-[0_-20px_100px_rgba(255,140,0,0.3)]"
    />
  </div>

  <!-- Glow detrás del crew -->
  <div
    class="pointer-events-none absolute bottom-[10%] left-1/2 z-[1] h-[320px] w-[320px] -translate-x-1/2 rounded-full bg-fuchsia-500/20 blur-[140px] sm:h-[420px] sm:w-[420px]"
  ></div>

  <!-- Fade inferior -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 z-[2] h-64 bg-gradient-to-t from-[rgba(4,6,18,1)] via-[rgba(4,6,18,0.9)] via-35% to-transparent"
  ></div>

  <!-- Fade lateral para desktop -->
  <div
    class="pointer-events-none absolute inset-y-0 right-0 z-[2] hidden lg:block w-[40%] bg-[linear-gradient(to_left,rgba(4,6,18,0.56)_0%,rgba(4,6,18,0.2)_44%,transparent_100%)]"
  ></div>

  <div
    class="container-shell relative z-10 flex min-h-[calc(100vh-5rem)] items-center"
  >
    <div class="grid w-full items-center gap-12 lg:grid-cols-2">
      <!-- Mobile épico centrado -->
      <div
        class="relative z-20 mx-auto flex max-w-4xl flex-col items-center text-center pb-[20rem] sm:pb-[26rem] lg:mx-0 lg:items-start lg:text-left lg:pb-0"
      >
        <span
          class="inline-flex rounded-full border border-cyan-300/25 bg-white/6 px-4 py-2 text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-cyan-200 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur-md sm:px-5 sm:py-2.5 sm:text-xs"
        >
          Podcast · Shows · Miami · Comunidad
        </span>

        <h1
          class="mt-6 text-[4.4rem] leading-[1] text-white sm:text-[5.4rem] lg:text-[6.5rem] xl:text-[7rem]"
        >
          SOMOS LOS<br />
          <span class="text-gradient-electric">PICHY BOYS</span>
        </h1>

        <p
          class="mt-6 max-w-[34rem] text-lg leading-8 text-[rgb(var(--color-text-secondary))] sm:text-xl"
        >
          el podcast #1 de comedia en español
        </p>

        <div
          class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:flex-wrap sm:justify-center lg:justify-start"
        >
          <a
            href="#shows"
            class="button-primary inline-flex min-w-[220px] justify-center rounded-full px-7 py-4 text-base font-semibold transition hover:-translate-y-1"
          >
            Explorar shows
          </a>

          <a
            href="#episodios"
            class="button-secondary inline-flex min-w-[220px] justify-center rounded-full px-7 py-4 text-base font-semibold transition hover:-translate-y-1"
          >
            Ver episodios
          </a>
        </div>
      </div>

      <div class="relative hidden lg:block">
        <div
          class="absolute bottom-12 left-10 h-72 w-72 rounded-full bg-cyan-400/30 blur-[130px]"
        ></div>
        <div
          class="absolute right-10 top-10 h-56 w-56 rounded-full bg-fuchsia-500/30 blur-[130px]"
        ></div>
      </div>
    </div>
  </div>
</section>
<section id="comunidad" class="section-shell">
  <div class="container-shell">
    <div class="glow-panel overflow-hidden p-8 md:p-10">
      <div class="max-w-3xl">
        <p class="section-kicker">Comunidad</p>
        <h2 class="mt-4 text-5xl text-white md:text-6xl">
          Quédate cerca del próximo momento.
        </h2>
        <p
          class="mt-5 text-lg leading-8 text-[rgb(var(--color-text-secondary))]"
        >
          Placeholder para captación: newsletter, alertas de shows, drops de
          merch o beneficios para fans.
        </p>
      </div>

      <form class="mt-10 grid gap-4 md:grid-cols-[1fr_auto]">
        <input
          type="email"
          placeholder="Tu email"
          class="rounded-full border border-white/10 bg-white/5 px-6 py-4 text-white outline-none placeholder:text-[rgb(var(--color-text-secondary))]"
        />
        <button
          type="submit"
          class="button-primary rounded-full px-7 py-4 text-base font-semibold"
        >
          Unirme
        </button>
      </form>
    </div>
  </div>
</section>

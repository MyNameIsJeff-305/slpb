<section id="comunidad" class="section-shell">
  <div class="container-shell">
    <div class="glow-panel overflow-hidden p-8 md:p-10">
      <div class="max-w-3xl">
        <p class="section-kicker">Comunidad</p>
        <h2 class="mt-4 text-5xl text-white md:text-6xl">
          Quédate cerca del próximo momento.
        </h2>
        <p
          class="mt-5 text-lg leading-8 text-[rgb(var(--color-text-secondary))]"
        >
          Únete a la comunidad de Los Pichy Boys para recibir noticias, próximos
          shows, drops especiales y sorpresas exclusivas para fans.
        </p>
      </div>

      <form
        name="pichy-community"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="mt-10 grid gap-4 md:grid-cols-[1fr_1fr_auto]"
      >

        <!-- Honeypot field for spam protection -->
        <p class="hidden">
          <label>
            Don’t fill this out if you’re human:
            <input name="bot-field" />
          </label>
        </p>

        <input
          type="text"
          name="name"
          placeholder="Tu nombre"
          required
          class="rounded-full border border-white/10 bg-white/5 px-6 py-4 text-white outline-none placeholder:text-[rgb(var(--color-text-secondary))] focus:border-[rgb(var(--color-neon-cyan))]/60"
        />

        <input
          type="email"
          name="email"
          placeholder="Tu email"
          required
          class="rounded-full border border-white/10 bg-white/5 px-6 py-4 text-white outline-none placeholder:text-[rgb(var(--color-text-secondary))] focus:border-[rgb(var(--color-neon-cyan))]/60"
        />

        <button
          type="submit"
          class="button-primary rounded-full px-7 py-4 text-base font-semibold"
        >
          Unirme
        </button>
      </form>
    </div>
  </div>
</section>

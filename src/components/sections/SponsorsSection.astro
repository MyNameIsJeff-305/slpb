---
const sponsors = [
  {
    name: "Noma Beach",
    logo: "/images/sponsors/noma-beach.webp",
    description:
      "NOMA BEACH at Redfish is a one-of-a-kind waterfront destination featuring Chef Donatella Arpaia’s signature Coastal Italian cuisine.",
    website: "https://www.noma-beach.com/",
    category: "Waterfront Dining",
  },
  {
    name: "Techo Guys",
    logo: "/images/sponsors/techo-guys.webp",
    description:
      "Roofing experts for repairs, replacements, and new installations, focused on quality, trust, and customer satisfaction.",
    website: "https://www.techo-guys.com/",
    category: "Roofing Services",
  },
  {
    name: "Elly Wellness",
    logo: "/images/sponsors/elly-wellness.webp",
    description:
      "A beauty and wellness destination guided by passionate experts with decades of combined experience.",
    website: "https://ellywellness.com/",
    category: "Beauty & Wellness",
  },
  {
    name: "Bomnin",
    logo: "/images/sponsors/bomnin.webp",
    description:
      "South Florida’s destination for Jeep, Chrysler, Dodge, and Ram vehicles with a strong presence in the local community.",
    website: "https://www.bomninchryslerdodgejeepram.com/",
    category: "Automotive",
  },
];
---

<section id="sponsors" class="section-shell relative overflow-hidden">
  <!-- Background energy -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute left-1/2 top-10 h-[420px] w-[420px] -translate-x-1/2 rounded-full bg-[rgb(var(--color-neon-cyan))]/10 blur-[120px]"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 h-[360px] w-[360px] rounded-full bg-[rgb(var(--color-neon-pink))]/10 blur-[120px]"
    >
    </div>
  </div>

  <div class="container-shell">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div class="max-w-3xl">
        <p class="section-kicker">Sponsors / partners</p>

        <h2 class="mt-4 text-5xl text-white md:text-6xl">
          Marcas que se montan en el viaje con Los Pichy Boys.
        </h2>

        <p class="mt-5 text-lg leading-8 text-[rgb(var(--color-text-secondary))]">
          Nuestros sponsors forman parte de una plataforma con show, comunidad,
          cultura, humor y una audiencia que conecta con marcas reales.
        </p>
      </div>

      <div class="glow-panel relative overflow-hidden p-6">
        <div
          class="absolute -right-16 -top-16 h-40 w-40 rounded-full bg-[rgb(var(--color-neon-cyan))]/20 blur-3xl"
        >
        </div>

        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[rgb(var(--color-neon-cyan))]">
          Partnership opportunities
        </p>

        <h3 class="mt-4 text-2xl text-white">
          Tu marca puede ser parte del universo Pichy.
        </h3>

        <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
          Integraciones, menciones, activaciones, eventos, contenido digital y
          presencia dentro de una comunidad que vive el humor cubano con energía.
        </p>

        <a
          href="mailto:partnerships@lospichyboys.com"
          class="mt-6 inline-flex items-center justify-center rounded-full border border-white/15 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-white transition duration-300 hover:-translate-y-1 hover:border-[rgb(var(--color-neon-cyan))]/60 hover:bg-white/10"
        >
          Conviértete en sponsor
        </a>
      </div>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        sponsors.map((sponsor) => (
          <a
            href={sponsor.website}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Visit ${sponsor.name} website`}
            class="group glow-panel relative flex min-h-[360px] flex-col overflow-hidden p-5 transition duration-300 hover:-translate-y-2 hover:border-white/20"
          >
            <!-- Card glow -->
            <div class="pointer-events-none absolute inset-0 opacity-0 transition duration-500 group-hover:opacity-100">
              <div class="absolute -right-20 -top-20 h-44 w-44 rounded-full bg-[rgb(var(--color-neon-pink))]/20 blur-3xl"></div>
              <div class="absolute -bottom-20 -left-20 h-44 w-44 rounded-full bg-[rgb(var(--color-neon-cyan))]/20 blur-3xl"></div>
            </div>

            <!-- Logo/Image box -->
            <div class="relative h-[150px] w-full overflow-hidden rounded-[1.4rem] border border-white/10 bg-white/[0.04] transition duration-300 group-hover:bg-white/[0.07]">
              <img
                src={sponsor.logo}
                alt={`${sponsor.name} logo`}
                loading="lazy"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              />
            </div>

            <div class="relative mt-6 flex flex-1 flex-col">
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-neon-cyan))]">
                {sponsor.category}
              </p>

              <h3 class="mt-3 text-2xl text-white">{sponsor.name}</h3>

              <p class="mt-3 flex-1 text-sm leading-7 text-[rgb(var(--color-text-secondary))]">
                {sponsor.description}
              </p>

              <div class="mt-6 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.16em] text-white/60 transition duration-300 group-hover:text-[rgb(var(--color-neon-cyan))]">
                Click para visitar
                <span class="transition duration-300 group-hover:translate-x-1">
                  →
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
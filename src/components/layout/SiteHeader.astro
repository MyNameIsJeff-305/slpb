---
const navItems = [
  { label: "Shows", href: "#shows" },
  { label: "Episodios", href: "#podcasts" },
  { label: "Universo", href: "#universo" },
  { label: "Merch", href: "#merch" },
  { label: "Sponsors", href: "#sponsors" },
  { label: "Comunidad", href: "#comunidad" },
];

import EmailIcon from "../icons/EmailIcon.astro";
---

<header class="fixed inset-x-0 top-0 z-50">
  <div class="container-shell pt-4">
    <div
      class="glow-panel flex min-h-[72px] items-center justify-between px-4 md:px-6"
    >
      <a href="#top" class="flex items-center gap-3">
        <!-- PLACEHOLDER:
             Reemplaza este bloque por el logo real principal.
             Ruta esperada sugerida: /images/branding/pichy-logo-main.png
             Mientras tanto usamos una caja visual para mantener spacing, altura y balance del header. -->
        <div
          class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white/10 text-sm font-extrabold text-[rgb(var(--color-neon-cyan))] shadow-[var(--shadow-glow-blue)]"
        >
          <img
            src="/images/branding/pichy-logo-main.png"
            alt="Logo de Los Pichy Boys"
            class="h-11 w-auto p-0 object-contain rounded-2xl"
          />
        </div>
        <div class="leading-none">
          <p
            class="text-xs uppercase tracking-[0.28em] text-[rgb(var(--color-neon-cyan))]"
          >
            Somos
          </p>
          <p class="text-sm font-semibold text-white">Los Pichy Boys</p>
        </div>
      </a>

      <nav class="hidden items-center gap-6 lg:flex">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-sm font-medium text-[rgb(var(--color-text-secondary))] transition hover:text-white"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <a
        href="mailto:sales@lospichyboys.com"
        class="button-primary animate-boing inline-flex items-center rounded-full px-5 py-3 text-sm font-semibold transition duration-300 hover:-translate-y-0.5"
      >
        <!-- Este span solo sera visible en dispositivos moviles -->
        <span class="hidden lg:inline">Anúnciate con Nosotros</span>

        <!-- Este span sera invisible en moviles -->
        <span class="inline lg:hidden"><EmailIcon class="h-4 w-4" /></span>
      </a>
    </div>
  </div>
</header>
